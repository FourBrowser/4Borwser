// TypeScript configuration

{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/ui/*"],
      "@core/*": ["src/core/*"],
      "@engine/*": ["src/engine/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["src/**/*", "ui/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"]
}
