  "search": {
    "suggest_enabled": true
  },

  "safebrowsing": {
    "enabled": true
  },

  "credentials_enable_autosignin": false,
  "credentials_enable_service": true,

  "cookies_and_site_data": {
    "local_storage_access_enabled": true,
    "cookies_enabled": true
