// Default preferences file for 4Browser
// Similar to Chrome's Preferences file structure

{
  "profile": {
    "name": "Default",
    "avatar_icon": "chrome://theme/IDR_PROFILE_AVATAR_0",
    "local_profile_id": 0
  },

  "bookmark_bar": {
    "show_on_all_tabs": true
  },

  "browser": {
